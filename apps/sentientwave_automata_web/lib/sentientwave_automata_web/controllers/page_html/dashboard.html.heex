<.admin_shell
  flash={@flash}
  title="Admin Dashboard"
  subtitle="Operate Automata, Matrix, and Temporal from a single internal console."
  status={@status}
  admin_user={@admin_user}
  nav={@nav}
>
  <section class="sw-grid sw-grid-3">
    <article class="sw-card">
      <h2 class="sw-card-title">Automata API</h2>
      <p class="sw-card-copy">Core orchestration service health and entrypoint.</p>
      <a href={@status.automata_url} target="_blank" rel="noreferrer" class="sw-link">
        {@status.automata_url}
      </a>
    </article>

    <article class="sw-card">
      <h2 class="sw-card-title">Matrix Homeserver</h2>
      <p class="sw-card-copy">Room messaging surface for humans and agents.</p>
      <a href={@status.matrix_url} target="_blank" rel="noreferrer" class="sw-link">
        {@status.matrix_url}
      </a>
    </article>

    <article class="sw-card">
      <h2 class="sw-card-title">Temporal UI</h2>
      <p class="sw-card-copy">Durable workflow runtime observability and inspection.</p>
      <a href={@status.temporal_ui_url} target="_blank" rel="noreferrer" class="sw-link">
        {@status.temporal_ui_url}
      </a>
    </article>
  </section>

  <section class="sw-grid sw-grid-2">
    <a href={~p"/onboarding"} class="sw-action-card">
      <h3>Onboarding Studio</h3>
      <p>Create launch kits with deep links, QR codes, and setup instructions for each user.</p>
      <span>Open onboarding</span>
    </a>

    <a href={~p"/directory/users"} class="sw-action-card">
      <h3>Directory</h3>
      <p>
        Manage humans, agents, and service identities with credentials, runtime state, and schedules.
      </p>
      <span>Open directory</span>
    </a>

    <a href={~p"/constitution"} class="sw-action-card">
      <h3>Constitution</h3>
      <p>
        Publish laws, manage governance roles, and review Matrix-driven proposals before they shape agents.
      </p>
      <span>Open constitution</span>
    </a>

    <a href={~p"/settings/skills"} class="sw-action-card">
      <h3>Skill Catalog</h3>
      <p>
        Publish organization skills once, then designate or roll them back on specific agents.
      </p>
      <span>Manage skills</span>
    </a>

    <a href={~p"/settings/llm"} class="sw-action-card">
      <h3>LLM Providers</h3>
      <p>Manage multiple providers, set defaults, and adjust model timeout and credentials.</p>
      <span>Configure providers</span>
    </a>

    <a href={~p"/settings/tools"} class="sw-action-card">
      <h3>Tool Registry</h3>
      <p>Enable and maintain tools agents can call, including Brave search and system tools.</p>
      <span>Manage tools</span>
    </a>
  </section>
</.admin_shell>
