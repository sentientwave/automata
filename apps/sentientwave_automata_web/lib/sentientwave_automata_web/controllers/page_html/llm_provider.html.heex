<.admin_shell
  flash={@flash}
  title={"Edit Provider: #{@provider.name}"}
  subtitle="Adjust model routing, timeout, endpoint, and credentials with provider-aware setup guidance."
  status={@status}
  admin_user={@admin_user}
  nav={@nav}
>
  <section class="sw-card">
    <div class="sw-inline-actions">
      <a href={~p"/settings/llm"} class="sw-btn sw-btn-ghost">Back to provider table</a>
      <form action={~p"/settings/llm/providers/#{@provider.id}/default"} method="post">
        <input type="hidden" name="_csrf_token" value={Plug.CSRFProtection.get_csrf_token()} />
        <button type="submit" class="sw-btn sw-btn-ghost" disabled={@provider.is_default}>
          Set Default
        </button>
      </form>
      <form action={~p"/settings/llm/providers/#{@provider.id}"} method="post">
        <input type="hidden" name="_csrf_token" value={Plug.CSRFProtection.get_csrf_token()} />
        <input type="hidden" name="_method" value="delete" />
        <button type="submit" class="sw-btn sw-btn-danger">Delete Provider</button>
      </form>
    </div>

    <div class="sw-pill-list mt-4">
      <span class="sw-pill">Provider: {llm_provider_label(@provider.provider)}</span>
      <span class="sw-pill">Model: {@provider.model}</span>
      <span class="sw-pill">Timeout: {@provider.timeout_seconds || 600}s</span>
      <span class={["sw-pill", @provider.is_default && "is-ok"]}>
        {if @provider.is_default, do: "Default", else: "Secondary"}
      </span>
      <span class={["sw-pill", @provider.enabled && "is-ok"]}>
        {if @provider.enabled, do: "Enabled", else: "Disabled"}
      </span>
    </div>
  </section>

  <.provider_setup_panel provider={@provider.provider} />

  <section class="sw-card">
    <h2 class="sw-card-title">Provider Configuration</h2>
    <form
      id="provider-form-edit"
      action={~p"/settings/llm/providers/#{@provider.id}"}
      method="post"
      class="sw-form-grid mt-5"
      data-provider-form
      data-provider-mode="edit"
    >
      <input type="hidden" name="_csrf_token" value={Plug.CSRFProtection.get_csrf_token()} />

      <label class="sw-field">
        <span>Display Name</span>
        <input name="llm[name]" class="sw-input" value={@provider.name} />
      </label>

      <label class="sw-field">
        <span>Slug</span>
        <input name="llm[slug]" class="sw-input" value={@provider.slug} />
      </label>

      <label class="sw-field">
        <span>Provider</span>
        <select
          id="llm-provider-select-edit"
          name="llm[provider]"
          class="sw-select"
          data-provider-select
        >
          <%= for {label, value} <- @provider_options do %>
            <option value={value} selected={@provider.provider == value}>{label}</option>
          <% end %>
        </select>
        <p class="sw-field-help">
          Changing provider does not replace your model or endpoint automatically. Review the setup panel above if you switch.
        </p>
      </label>

      <label class="sw-field">
        <span>Model</span>
        <input
          id="llm-model-edit"
          name="llm[model]"
          class="sw-input"
          value={@provider.model}
          placeholder="gpt-5.4 / gemini-3.1-pro-preview / claude-sonnet-4-6 / gpt-oss-120b / openrouter/auto / gpt-oss:20b / qwen3-next-80b"
          data-provider-model-input
        />
        <p class="sw-field-help" data-provider-model-copy>
          Update the model explicitly if you want to follow another provider preset.
        </p>
      </label>

      <label class="sw-field">
        <span>Timeout (seconds)</span>
        <input
          name="llm[timeout_seconds]"
          type="number"
          min="1"
          max="3600"
          class="sw-input"
          value={@provider.timeout_seconds || 600}
        />
      </label>

      <label class="sw-field sw-field-span">
        <span>Base URL (optional)</span>
        <input
          id="llm-base-url-edit"
          name="llm[base_url]"
          class="sw-input"
          value={@provider.base_url}
          placeholder="https://generativelanguage.googleapis.com/v1beta or https://api.cerebras.ai/v1"
          data-provider-base-url-input
        />
        <p class="sw-field-help" data-provider-base-url-copy>
          Leave blank to use the selected provider default endpoint.
        </p>
      </label>

      <label class="sw-field sw-field-span">
        <span data-provider-token-label>API Token (leave blank to keep existing)</span>
        <input
          name="llm[api_token]"
          type="password"
          class="sw-input"
          value=""
          data-provider-token-input
        />
        <p class="sw-field-help" data-provider-token-copy>
          Save a new provider credential here, or leave it blank to keep the existing secret.
        </p>
      </label>

      <label class="sw-checkbox-row">
        <input type="checkbox" name="llm[enabled]" value="1" checked={@provider.enabled} />
        <span>Enabled</span>
      </label>

      <label class="sw-checkbox-row">
        <input type="checkbox" name="llm[clear_api_token]" value="1" />
        <span>Clear saved token</span>
      </label>

      <div class="sw-field-span sw-actions">
        <button type="submit" class="sw-btn sw-btn-primary">Save Provider</button>
      </div>
    </form>
  </section>
</.admin_shell>
