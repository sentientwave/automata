<.admin_shell
  flash={@flash}
  title="Add Provider"
  subtitle="Create a new provider with provider-aware defaults, endpoint guidance, and credential hints."
  status={@status}
  admin_user={@admin_user}
  nav={@nav}
>
  <section class="sw-card">
    <div class="sw-inline-actions">
      <a href={~p"/settings/llm"} class="sw-btn sw-btn-ghost">Back to provider table</a>
    </div>
  </section>

  <section class="sw-card">
    <div class="sw-section-header">
      <div>
        <h2 class="sw-card-title">Quick Presets</h2>
        <p class="sw-card-copy">
          Jump into a provider preset to load the right setup guidance before you save.
        </p>
      </div>
    </div>

    <div class="sw-pill-list mt-4">
      <a href={~p"/settings/llm/providers/new?provider=local"} class="sw-btn sw-btn-ghost">
        Local
      </a>
      <a href={~p"/settings/llm/providers/new?provider=openai"} class="sw-btn sw-btn-ghost">
        OpenAI
      </a>
      <a href={~p"/settings/llm/providers/new?provider=gemini"} class="sw-btn sw-btn-ghost">
        Google Gemini
      </a>
      <a href={~p"/settings/llm/providers/new?provider=anthropic"} class="sw-btn sw-btn-ghost">
        Anthropic
      </a>
      <a href={~p"/settings/llm/providers/new?provider=cerebras"} class="sw-btn sw-btn-ghost">
        Cerebras
      </a>
      <a href={~p"/settings/llm/providers/new?provider=openrouter"} class="sw-btn sw-btn-ghost">
        OpenRouter
      </a>
      <a href={~p"/settings/llm/providers/new?provider=lm-studio"} class="sw-btn sw-btn-ghost">
        LM Studio
      </a>
      <a href={~p"/settings/llm/providers/new?provider=ollama"} class="sw-btn sw-btn-ghost">
        Ollama
      </a>
    </div>
  </section>

  <.provider_setup_panel provider={@selected_provider} />

  <section class="sw-card">
    <h2 class="sw-card-title">New Provider</h2>
    <form
      id="provider-form-new"
      action={~p"/settings/llm/providers"}
      method="post"
      class="sw-form-grid mt-5"
      data-provider-form
      data-provider-mode="new"
    >
      <input type="hidden" name="_csrf_token" value={Plug.CSRFProtection.get_csrf_token()} />

      <label class="sw-field">
        <span>Display Name</span>
        <input name="llm[name]" class="sw-input" placeholder="Primary Provider" />
      </label>

      <label class="sw-field">
        <span>Slug (optional)</span>
        <input name="llm[slug]" class="sw-input" placeholder="primary-provider" />
      </label>

      <label class="sw-field">
        <span>Provider</span>
        <select
          id="llm-provider-select-new"
          name="llm[provider]"
          class="sw-select"
          data-provider-select
        >
          <%= for {label, value} <- @provider_options do %>
            <option value={value} selected={@selected_provider == value}>{label}</option>
          <% end %>
        </select>
        <p class="sw-field-help">
          Choose a hosted or local provider, then review the setup panel above before saving.
        </p>
      </label>

      <label class="sw-field">
        <span>Model</span>
        <input
          id="llm-model-new"
          name="llm[model]"
          class="sw-input"
          placeholder="gpt-5.4 / gemini-3.1-pro-preview / claude-sonnet-4-6 / gpt-oss-120b / openrouter/auto / gpt-oss:20b / qwen3-next-80b"
          data-provider-model-input
        />
        <p class="sw-field-help" data-provider-model-copy>
          Leave blank to use the selected provider default model.
        </p>
      </label>

      <label class="sw-field">
        <span>Timeout (seconds)</span>
        <input
          name="llm[timeout_seconds]"
          type="number"
          min="1"
          max="3600"
          class="sw-input"
          value="600"
        />
      </label>

      <label class="sw-field sw-field-span">
        <span>Base URL (optional)</span>
        <input
          id="llm-base-url-new"
          name="llm[base_url]"
          class="sw-input"
          placeholder="https://generativelanguage.googleapis.com/v1beta or https://api.cerebras.ai/v1"
          data-provider-base-url-input
        />
        <p class="sw-field-help" data-provider-base-url-copy>
          Leave blank to use the selected provider default endpoint.
        </p>
      </label>

      <label class="sw-field sw-field-span">
        <span data-provider-token-label>API Token (optional)</span>
        <input name="llm[api_token]" type="password" class="sw-input" data-provider-token-input />
        <p class="sw-field-help" data-provider-token-copy>
          Save a provider credential here, or rely on your runtime environment if you prefer.
        </p>
      </label>

      <label class="sw-checkbox-row">
        <input type="checkbox" name="llm[enabled]" value="1" checked />
        <span>Enabled</span>
      </label>

      <label class="sw-checkbox-row">
        <input type="checkbox" name="llm[is_default]" value="1" />
        <span>Set as default</span>
      </label>

      <div class="sw-field-span sw-actions">
        <button type="submit" class="sw-btn sw-btn-primary">Add Provider</button>
      </div>
    </form>
  </section>
</.admin_shell>
