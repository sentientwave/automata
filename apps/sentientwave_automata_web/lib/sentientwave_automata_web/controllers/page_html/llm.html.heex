<.admin_shell
  flash={@flash}
  title="Provider Management"
  subtitle="Configure multiple inference providers and switch default behavior instantly."
  status={@status}
  admin_user={@admin_user}
  nav={@nav}
>
  <section class="sw-card">
    <h2 class="sw-card-title">Effective Runtime Provider</h2>
    <div class="sw-pill-list mt-4">
      <span class="sw-pill">Name: {@llm.name}</span>
      <span class="sw-pill">Provider: {llm_provider_label(@llm.provider)}</span>
      <span class="sw-pill">Model: {@llm.model}</span>
      <span class="sw-pill">Timeout: {@llm.timeout_seconds}s</span>
      <span class="sw-pill">
        Token: {if @token_configured?, do: "configured", else: "not set"}
      </span>
      <span class="sw-pill">Source: {if @persisted?, do: "database", else: "environment"}</span>
    </div>
  </section>

  <section class="sw-card">
    <div class="sw-section-header">
      <div>
        <h2 class="sw-card-title">Configured Providers</h2>
        <p class="sw-card-copy">
          Maintain multiple providers for fallback, locality, and cost control.
        </p>
      </div>
      <a href={~p"/settings/llm/providers/new"} class="sw-btn sw-btn-primary">Add Provider</a>
    </div>

    <div class="sw-table-wrap mt-5">
      <table class="sw-data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Provider</th>
            <th>Model</th>
            <th>Timeout</th>
            <th>Endpoint</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr :for={provider <- @providers}>
            <td>
              <div class="sw-table-primary">{provider.name}</div>
              <div class="sw-table-secondary">{provider.slug}</div>
            </td>
            <td>{llm_provider_label(provider.provider)}</td>
            <td><code>{provider.model}</code></td>
            <td>{provider.timeout_seconds || 600}s</td>
            <td class="sw-table-endpoint">
              {if provider.base_url in [nil, ""], do: "default endpoint", else: provider.base_url}
            </td>
            <td>
              <div class="sw-pill-list">
                <span class={["sw-pill", provider.is_default && "is-ok"]}>
                  {if provider.is_default, do: "Default", else: "Secondary"}
                </span>
                <span class={["sw-pill", provider.enabled && "is-ok"]}>
                  {if provider.enabled, do: "Enabled", else: "Disabled"}
                </span>
              </div>
            </td>
            <td>
              <div class="sw-table-actions">
                <a
                  href={~p"/settings/llm/providers/#{provider.id}"}
                  class="sw-btn sw-btn-ghost sw-btn-small"
                >
                  Configure
                </a>
                <form action={~p"/settings/llm/providers/#{provider.id}/default"} method="post">
                  <input
                    type="hidden"
                    name="_csrf_token"
                    value={Plug.CSRFProtection.get_csrf_token()}
                  />
                  <button
                    type="submit"
                    class="sw-btn sw-btn-ghost sw-btn-small"
                    disabled={provider.is_default}
                  >
                    Set Default
                  </button>
                </form>
                <form action={~p"/settings/llm/providers/#{provider.id}"} method="post">
                  <input
                    type="hidden"
                    name="_csrf_token"
                    value={Plug.CSRFProtection.get_csrf_token()}
                  />
                  <input type="hidden" name="_method" value="delete" />
                  <button type="submit" class="sw-btn sw-btn-danger sw-btn-small">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</.admin_shell>
